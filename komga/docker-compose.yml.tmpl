services:
  komga:
    image: gotson/komga:1.14.1
    container_name: komga
    restart: unless-stopped
    user: "1000:1000"
    ports:
      - "{{index . "web_port"}}:25600"
    environment:
      - TZ={{index . "timezone"}}
    deploy:
      resources:
        limits:
          memory: 512M
          pids: 200
    volumes:
      - {{index . "data_dir"}}/config:/config
      - {{if index . "library_path"}}{{index . "library_path"}}{{else}}{{index . "data_dir"}}/library{{end}}:/data
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:25600/api/v1/actuator/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

    labels:
      - "arabackup.enable=true"
      - "arabackup.borg.paths=config"
networks:
  {{index . "network"}}:
    external: true
