services:
  loki:
    image: grafana/loki:3.4.2
    container_name: loki
    command: -config.file=/etc/loki/local-config.yaml
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:3100"
    environment:
      - TZ={{index . "timezone"}}
    deploy:
      resources:
        limits:
          memory: 512M
          pids: 200
    volumes:
      - {{index . "data_dir"}}/data:/loki
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:3100/ready || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    security_opt:
      - no-new-privileges:true
    networks:
      - {{index . "network"}}

    labels:
      - "arabackup.enable=true"
      - "arabackup.borg.paths=data"
networks:
  {{index . "network"}}:
    external: true
