services:
  adguard:
    image: adguard/adguardhome:v0.107.72
    container_name: adguard
    entrypoint: ["/bin/sh", "-c"]
    command:
      - |
        sed -i 's/address: 0.0.0.0:80$$/address: 0.0.0.0:3000/' /opt/adguardhome/conf/AdGuardHome.yaml 2>/dev/null
        exec /opt/adguardhome/AdGuardHome --no-check-update -c /opt/adguardhome/conf/AdGuardHome.yaml -w /opt/adguardhome/work
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:3000/tcp"
      - "{{index . "dns_port"}}:53/tcp"
      - "{{index . "dns_port"}}:53/udp"
    environment:
      - TZ={{index . "timezone"}}
    deploy:
      resources:
        limits:
          memory: 256M
          pids: 200
    volumes:
      - {{index . "data_dir"}}/work:/opt/adguardhome/work
      - {{index . "data_dir"}}/conf:/opt/adguardhome/conf
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:3000 || ([ -s /opt/adguardhome/conf/AdGuardHome.yaml ] && kill 1; exit 1)"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    security_opt:
      - no-new-privileges:true
    networks:
      - {{index . "network"}}

networks:
  {{index . "network"}}:
    external: true
