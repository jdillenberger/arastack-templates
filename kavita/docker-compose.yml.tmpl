services:
  kavita:
    image: jvmilazz0/kavita:0.8.4.2
    container_name: kavita
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:5000"
    environment:
      - TZ={{index . "timezone"}}
    deploy:
      resources:
        limits:
          memory: 512M
          pids: 200
    volumes:
      - {{index . "data_dir"}}/config:/kavita/config
      - {{if index . "library_path"}}{{index . "library_path"}}{{else}}{{index . "data_dir"}}/library{{end}}:/manga
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:5000/api/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    security_opt:
      - no-new-privileges:true
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - {{index . "network"}}

    labels:
      - "arabackup.enable=true"
      - "arabackup.borg.paths=config"
networks:
  {{index . "network"}}:
    external: true
