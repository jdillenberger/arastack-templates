services:
  telegraf:
    image: telegraf:1.34
    container_name: telegraf
    restart: unless-stopped
    hostname: {{index . "hostname"}}
    environment:
      - TZ={{index . "timezone"}}
      - HOST_PROC=/host/proc
      - HOST_SYS=/host/sys
      - HOST_ETC=/host/etc
      - HOST_MOUNT_PREFIX=/host
      - TELEGRAF_HOSTNAME={{index . "hostname"}}
      - TELEGRAF_INTERVAL={{index . "collect_interval"}}
      - MQTT_HOST={{index . "mqtt_host"}}
      - MQTT_PORT={{index . "mqtt_port"}}
      - MQTT_TOPIC_PREFIX={{index . "mqtt_topic_prefix"}}
      - MQTT_USERNAME={{index . "mqtt_username"}}
      - MQTT_PASSWORD={{index . "mqtt_password"}}
    deploy:
      resources:
        limits:
          memory: 512M
          pids: 100
    volumes:
      - ./telegraf.conf:/etc/telegraf/telegraf.conf:ro
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /etc:/host/etc:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    network_mode: host
    security_opt:
      - no-new-privileges:true
