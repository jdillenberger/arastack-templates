services:
  trilium:
    image: triliumnext/notes:v0.93.0
    container_name: trilium
    restart: unless-stopped
    ports:
      - "{{index . "web_port"}}:8080"
    environment:
      - TZ={{index . "timezone"}}
      - TRILIUM_DATA_DIR=/home/node/trilium-data
    deploy:
      resources:
        limits:
          memory: 256M
          pids: 200
    volumes:
      - {{index . "data_dir"}}/data:/home/node/trilium-data
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:8080/api/health-check || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    security_opt:
      - no-new-privileges:true
    networks:
      - {{index . "network"}}

    labels:
      - "arabackup.enable=true"
      - "arabackup.borg.paths=data"
networks:
  {{index . "network"}}:
    external: true
